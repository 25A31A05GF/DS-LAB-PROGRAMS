#include <iostream>
using namespace std;
void swap_by_value(int a, int b) {
    int temp;
    temp = a; 
    a = b;    
    b = temp; 
    cout << "Inside function: a = " << a << ", b = " << b << endl;
}
int main() {
    int x = 10, y = 20;
    cout << "Before function call: x = " << x << ", y = " << y << endl;
    swap_by_value(x, y);
    cout << "After function call: x = " << x << ", y = " << y << endl;
    return 0;
}
