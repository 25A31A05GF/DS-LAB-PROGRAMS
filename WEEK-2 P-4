#include <iostream>
using namespace std;
int main()
{
    int n, i;
    int *p;
    cout << "Enter n value: ";
    cin >> n;
    p = new int[n];
    cout << "Enter array elements: ";
    for(i = 0; i < n; i++)
    {
        cin >> *(p + i);
    }
    cout << "Array elements are: ";
    for(i = 0; i < n; i++)
    {
        cout << *(p + i) << " ";
    }
    delete[] p;
    return 0;
}
