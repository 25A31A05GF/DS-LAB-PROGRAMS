#include <iostream>
using namespace std;
int main() {
    int n, key;
    bool status = false;
    cout << "Enter n value and key value: ";
    cin >> n >> key;
    int arr[n];
    int low = 0, high = n - 1;
    cout << "Enter all array elements in sorted order: ";
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }
    while (low <= high) {
        int mid = (low + high) / 2;
        if (arr[mid] == key) {
            cout << key << " element found at " << mid << " location";
            status = true;
            break;
        }
        else if (arr[mid] < key) {
            low = mid + 1;
        }
        else {
            high = mid - 1;
        }
    }
    if (!status) {
        cout << "Element not found in the array";
    }
    return 0;
}
