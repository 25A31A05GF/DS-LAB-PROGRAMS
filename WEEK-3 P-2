#include <iostream>
using namespace std;

class student {
private:
    int roll;
    string name;
public:
    student(int x, string y) : roll(x), name(y) {}
    void display() {
        cout << "roll no is: " << roll << endl << "name is: " << name << endl;
    }
};

int main() {
    student s1(2, "pragati");
    student s2(4, "kumari");
    s1.display();
    s2.display();
    return 0;
}
